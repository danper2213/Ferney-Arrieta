# Copia este archivo a .env.local y reemplaza los valores.
# Supabase: Dashboard del proyecto → Settings → API
# - Project URL → NEXT_PUBLIC_SUPABASE_URL
# - anon public / "Publishable" key → NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Bunny Stream (video.bunnycdn.com) — Stream → tu biblioteca de video
# - Library ID: número de la biblioteca (p. ej. en la URL o en la vista general)
# - BUNNY_API_KEY: Stream API Key (cabecera AccessKey en la API; suele estar en API / configuración de la biblioteca)
# - BUNNY_SECURITY_KEY: clave de token firmado para embeds (seguridad del reproductor / URLs firmadas)
# Requerido para thumbnails: hostname CDN de la biblioteca (Stream → Delivery → CDN hostname)
BUNNY_CDN_HOSTNAME=vz-xxxxx.b-cdn.net
# Requerido si Token Authentication está activo en el Pull Zone (CDN → tu Pull Zone → Security → URL Token Authentication Key). No es BUNNY_SECURITY_KEY del embed.
BUNNY_CDN_TOKEN_KEY=
# Opcional: host del iframe (por defecto player.mediadelivery.net). Si el embed da 404, prueba iframe.mediadelivery.net
# BUNNY_EMBED_HOST=iframe.mediadelivery.net
BUNNY_LIBRARY_ID=
BUNNY_API_KEY=
BUNNY_SECURITY_KEY=
